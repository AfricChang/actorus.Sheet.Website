---
import { defaultLocale, localeMeta } from "../data/site";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=./${defaultLocale}/`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AcTorus.Sheet</title>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        font-family: "IBM Plex Sans", "Noto Sans SC", sans-serif;
        background: #f3eee5;
        color: #182230;
      }

      main {
        max-width: 36rem;
        padding: 2rem;
        text-align: center;
      }

      a {
        color: inherit;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>AcTorus.Sheet</h1>
      <p>Redirecting to the default locale.</p>
      <p>
        If redirection does not happen automatically,
        <a href={`./${defaultLocale}/`}>{localeMeta[defaultLocale].nativeLabel}</a>.
      </p>
    </main>
  </body>
</html>
