---
import { defaultLocale } from "../data/site";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Not Found | AcTorus.Sheet</title>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 2rem;
        font-family: "IBM Plex Sans", "Noto Sans SC", sans-serif;
        background: #f3eee5;
        color: #182230;
      }

      main {
        max-width: 36rem;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Page not found</h1>
      <p>The page may have moved between locales or has not been published yet.</p>
      <p>
        Try the default locale homepage:
        <a href={`./${defaultLocale}/`}>./{defaultLocale}/</a>
      </p>
    </main>
  </body>
</html>
