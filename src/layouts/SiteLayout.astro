---
import "../styles/global.css";

import {
  buildLocaleHref,
  buildLocalePath,
  getNavItems,
  localeMeta,
  resolveLink,
  routes,
  siteCopy,
  siteName,
  supportedLocales,
  type Locale,
} from "../data/site";

interface Props {
  locale: Locale;
  relativePath: string;
  title: string;
  description: string;
}

const { locale, relativePath, title, description } = Astro.props;
const copy = siteCopy[locale];
const navItems = getNavItems(locale);
const pageTitle = title === siteName ? title : `${title} | ${siteName}`;
const publicBase = new URL(import.meta.env.BASE_URL, Astro.site ?? "https://africchang.github.io");
const canonicalUrl = new URL(buildLocalePath(locale, relativePath).replace(/^\//, ""), publicBase).toString();
const ogImageUrl = new URL("Images/social/og-default.svg", publicBase).toString();

function isActive(path: string) {
  return path === "/" ? relativePath === "/" : relativePath.startsWith(path);
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {
      supportedLocales.map((item) => (
        <link
          rel="alternate"
          hreflang={item}
          href={new URL(buildLocalePath(item, relativePath).replace(/^\//, ""), publicBase).toString()}
        />
      ))
    }
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&family=Noto+Sans+SC:wght@400;500;700&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="site-shell">
      <div class="announcement">
        <div class="container">{copy.announcement}</div>
      </div>
      <header class="site-header">
        <div class="container header-inner">
          <a class="brand-lockup" href={buildLocaleHref(locale, routes.home.path)}>
            <span class="brand-mark">
              <img src={`${import.meta.env.BASE_URL}Images/brand/actorus-mark.svg`} alt={`${siteName} mark`} />
            </span>
            <span class="brand-copy">
              <strong>{siteName}</strong>
              <span>{copy.siteDescription}</span>
            </span>
          </a>

          <div class="nav-cluster">
            <nav class="site-nav" aria-label="Primary">
              {
                navItems.map((item) => (
                  <a class:list={["nav-link", { active: isActive(item.path) }]} href={item.href}>
                    {item.label}
                  </a>
                ))
              }
            </nav>

            <div class="locale-switcher" aria-label="Language switcher">
              {
                supportedLocales.map((item) => (
                  <a
                    class:list={["locale-link", { active: item === locale }]}
                    href={buildLocaleHref(item, relativePath)}
                    lang={item}
                  >
                    {localeMeta[item].nativeLabel}
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer class="footer">
        <div class="container footer-inner">
          <div>
            <div class="brand-lockup">
              <span class="brand-mark">
                <img src={`${import.meta.env.BASE_URL}Images/brand/actorus-mark.svg`} alt={`${siteName} mark`} />
              </span>
              <span class="brand-copy">
                <strong>{siteName}</strong>
                <span>{copy.footerTagline}</span>
              </span>
            </div>
            <p class="footer-note">{copy.footerNote}</p>
          </div>

          <div class="footer-links">
            <a class="button ghost" href={resolveLink("productRepo", locale)} target="_blank" rel="noreferrer">
              GitHub
            </a>
            <a class="button ghost" href={resolveLink("docs", locale)}>
              {routes.docs.label[locale]}
            </a>
            <a class="button ghost" href={resolveLink("download", locale)}>
              {routes.download.label[locale]}
            </a>
            <a class="button primary" href={resolveLink("contact", locale)}>
              {routes.contact.label[locale]}
            </a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
